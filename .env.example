# Copy this file to `.env` and edit. `.env` is gitignored, so your local settings
# (endpoint, model, owner) never get committed.

# Ollama endpoint + model
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b

# Optional
# MC_OWNER=YourName        # who the bot protects / flees toward
# AGENT_HEARTBEAT=0        # >0 = auto-resume the last goal/job after N idle seconds
# MC_VERSION=              # blank = auto-detect (use a supported anchor to pin)
